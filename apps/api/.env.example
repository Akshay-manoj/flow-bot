# ─── Database ───────────────────────────────────────────────────────────────────
# Local (Docker Compose):
DATABASE_URL=postgresql://user:password@localhost:5432/flowbot
# Production (Neon):
# DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/flowbot?sslmode=require

# ─── Redis ──────────────────────────────────────────────────────────────────────
# Local (Docker Compose):
REDIS_URL=redis://localhost:6379
# Production (Upstash):
# REDIS_URL=rediss://:<token>@<host>.upstash.io:6380

# ─── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── App ────────────────────────────────────────────────────────────────────────
PORT=3000
# Origins allowed to connect to the WebSocket gateway (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
